<%
  service_terms = ["Service", "Diagnose", "Bremsen", "Elektronik", "Aufhängung", "Turbine", "Reifen", "MFK", "Wartung", "Fahrzeugcheck", "KlimaService", "Radwechsel"]

  values = [
    { icon: "award",        title: "Erfahrung",        text: "Seit über 25 Jahren reparieren, warten und diagnostizieren wir Fahrzeuge aller Marken mit geschultem Fachwissen." },
    { icon: "shield-check", title: "Qualität",          text: "Wir arbeiten ausschliesslich nach Herstellervorgaben und mit geprüften Ersatzteilen – für ein dauerhaftes Ergebnis." },
    { icon: "clock",        title: "Zuverlässigkeit",   text: "Termine, die wir vereinbaren, halten wir ein. Ihr Fahrzeug ist pünktlich fertig." },
    { icon: "scale",        title: "Fairness",          text: "Faire Preise und ehrliche Einschätzungen – auch wenn das bedeutet, von einer Reparatur abzuraten." },
  ]

  steps = [
    { title: "Diagnose &amp; Fahrzeugprüfung",       text: "Wir prüfen Ihr Fahrzeug sorgfältig und identifizieren die Ursache des Problems." },
    { title: "Transparente Offerte &amp; Beratung", text: "Sie erhalten eine verständliche Offerte und entscheiden in Ruhe, wie es weitergeht – keine versteckten Kosten." },
    { title: "Reparatur nach Herstellervorgaben",   text: "Unsere Mechaniker führen die Arbeiten fachgerecht aus und melden sich bei Ihnen, sobald das Fahrzeug bereit ist." },
  ]

  # 7 icons evenly distributed on a circle (radius 43.75%, starting at top)
  wheel_icons = [
    { name: "bremsen",     label: "Bremsen",    top:  6.25, left: 50.0 },
    { name: "aufhaengung", label: "Aufhängung", top: 22.7,  left: 84.2 },
    { name: "turbine",     label: "Turbine",    top: 59.7,  left: 92.7 },
    { name: "riemen",      label: "Riemen",     top: 89.4,  left: 69.0 },
    { name: "check",       label: "Check",      top: 89.4,  left: 31.0 },
    { name: "elektronik",  label: "Elektronik", top: 59.7,  left:  7.3 },
    { name: "mfk",         label: "MFK",        top: 22.7,  left: 15.8 },
  ]
%>

<main>
  <%# ---------------------------------------------------------------- %>
  <%# Hero %>
  <%# ---------------------------------------------------------------- %>
  <section id="startseite" class="relative min-h-screen flex items-center justify-center text-center px-6 bg-ink-900 bg-cover bg-center" style="background-image: url('<%= asset_path("hero/werkstatt-diagnose.jpg") %>');">

    <%# Strong layered overlay for readability %>
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(10,11,13,0.82) 0%, rgba(10,11,13,0.60) 50%, rgba(10,11,13,0.80) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center top, rgba(184,50,24,0.12) 0%, transparent 65%);"></div>

    <div class="relative z-10 max-w-3xl mx-auto pt-20">
      <%# Larger logo in hero %>
      <%= image_tag "logo/garage-hofwil-logo-weiss.png", alt: "Garage Hofwil AG", class: "h-20 md:h-28 mx-auto mb-10 drop-shadow-2xl" %>

      <h1 class="reveal font-heading text-4xl md:text-6xl font-semibold text-white leading-tight" data-controller="reveal">
        Ihr Mechaniker des Vertrauens<br class="hidden sm:block"> in der Region
      </h1>

      <p class="reveal mt-6 text-lg md:text-xl text-white/85 max-w-2xl mx-auto" data-controller="reveal" data-reveal-delay="100">
        Seit über 25 Jahren betreuen wir Fahrzeuge aller Marken &ndash; mit ehrlicher Beratung, klaren Offerten und persönlichem Service in Münchenbuchsee.
      </p>

      <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4" data-controller="reveal" data-reveal-delay="200">
        <a href="/kontakt" class="btn-primary btn-glow inline-flex items-center justify-center rounded-full px-8 py-4 font-heading text-base font-semibold">
          Gratis Fahrzeug Check
        </a>
        <a href="/leistungen" class="inline-flex items-center gap-1.5 font-heading text-base font-medium text-white/90 hover:text-white transition-colors">
          Alle Leistungen
          <%= render "pages/icon", name: "chevron-right", css_class: "w-4 h-4" %>
        </a>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Service banner marquee %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-ink-900 py-6 overflow-hidden" aria-label="Unsere Leistungen im Überblick">
    <div class="marquee-track">
      <% 2.times do %>
        <div class="flex items-center shrink-0">
          <% service_terms.each do |term| %>
            <span class="flex items-center font-heading text-lg md:text-xl font-medium text-mist-50 px-8">
              <%= term %>
              <span class="ml-8 w-1.5 h-1.5 rounded-full bg-brand-red" aria-hidden="true"></span>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Service wheel %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-mist-50 px-6 py-20 lg:py-[120px] overflow-hidden dm-light-1">
    <div class="max-w-[1200px] mx-auto grid items-center gap-16 lg:grid-cols-2">
      <div class="reveal" data-controller="reveal">
        <p class="font-heading text-sm font-semibold uppercase tracking-wider text-brand-red mb-3">Unsere Kernleistungen</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-ink-900">Alles aus einer Hand &ndash; für jede Fahrzeugmarke</h2>
        <p class="mt-6 text-mist-600 text-lg">
          Von der Diagnose über die Wartung bis zur Reparatur: Wir kümmern uns um Bremsen, Aufhängung, Elektronik, MFK-Vorbereitung und mehr &ndash; immer nach Herstellervorgaben.
        </p>
        <a href="/leistungen" class="btn-primary mt-8 inline-flex items-center rounded-full px-8 py-4 font-heading text-base font-semibold">
          Alle Leistungen ansehen
        </a>
      </div>

      <div class="reveal" data-controller="reveal" data-reveal-delay="150">
        <div class="relative w-72 h-72 sm:w-80 sm:h-80 md:w-[26rem] md:h-[26rem] mx-auto">
          <div class="absolute inset-0 rounded-full border border-mist-100" aria-hidden="true"></div>

          <div class="service-wheel absolute inset-0">
            <% wheel_icons.each do |icon| %>
              <div class="absolute" style="top: <%= icon[:top] %>%; left: <%= icon[:left] %>%; transform: translate(-50%, -50%);">
                <div class="service-wheel-icon-inner">
                  <div class="service-icon-card flex flex-col items-center gap-2">
                    <div class="service-icon-circle w-14 h-14 md:w-16 md:h-16 rounded-full border border-mist-100 bg-white text-ink-900 flex items-center justify-center shadow-sm">
                      <%= render "pages/icon", name: icon[:name], css_class: "w-6 h-6 md:w-7 md:h-7" %>
                    </div>
                    <span class="font-heading text-xs md:text-sm font-medium text-ink-900 bg-white/90 rounded px-1.5 whitespace-nowrap"><%= icon[:label] %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <%# Center logo %>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-ink-900 flex items-center justify-center shadow-lg">
              <%= image_tag "logo/garage-hofwil-logo-weiss.png", alt: "", class: "w-12 md:w-14" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Why choose us – adaptive section (light/dark mode aware) %>
  <%# ---------------------------------------------------------------- %>
  <section id="werte" class="werte-section px-6 py-20 lg:py-[120px]">
    <div class="max-w-[1200px] mx-auto">

      <%# Two-column: image left, text right %>
      <div class="grid gap-16 lg:grid-cols-2 items-center mb-16">

        <%# Single main image with red accent %>
        <div class="reveal relative" data-controller="reveal">
          <%# Decorative red accent behind image %>
          <div class="absolute -top-5 -left-5 w-24 h-24 bg-brand-red/12 rounded-2xl" aria-hidden="true"></div>

          <%# Main image %>
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] shadow-xl">
            <%= image_tag "team/mechaniker-1.jpg", alt: "Mechaniker bei der Arbeit in der Garage Hofwil", class: "w-full h-full object-cover" %>
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(184,50,24,0.07) 0%, transparent 55%);"></div>
            <%# Badge on the image %>
            <div class="absolute bottom-4 left-4 bg-brand-red text-white font-heading text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg">
              Über 25 Jahre Erfahrung
            </div>
          </div>
        </div>

        <%# Text content %>
        <div class="reveal werte-text lg:pl-6" data-controller="reveal" data-reveal-delay="150">
          <p class="font-heading text-sm font-semibold uppercase tracking-wider text-brand-red mb-4">Warum Garage Hofwil?</p>

          <h2 class="font-heading text-3xl md:text-4xl font-semibold leading-tight">
            Transparente Arbeit.<br>Schneller wieder unterwegs.
          </h2>

          <p class="mt-6 werte-para text-lg leading-relaxed">
            Bei Garage Hofwil erklären wir jede Arbeit klar und verständlich, bevor wir beginnen.
            <strong class="werte-strong">Transparenz</strong> bedeutet für uns: klare Offerten, ehrliche Einschätzungen und keine versteckten Kosten &ndash; egal wie gross oder klein der Auftrag.
          </p>

          <p class="mt-4 werte-para text-lg leading-relaxed">
            Wir verstehen, dass Sie Ihr Fahrzeug täglich brauchen. Deshalb steht
            <strong class="werte-strong">Geschwindigkeit</strong> bei uns an erster Stelle: effiziente Arbeit, kurze Wartezeiten und zuverlässige Terminplanung &ndash; damit Sie schnell wieder unterwegs sind.
          </p>

          <a href="/kontakt" class="btn-primary mt-8 inline-flex items-center rounded-full px-8 py-4 font-heading text-base font-semibold">
            Gratis Fahrzeug Check buchen
          </a>
        </div>
      </div>

      <%# Value cards row %>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <% values.each_with_index do |value, i| %>
          <div class="value-card-dark reveal rounded-2xl p-7" data-controller="reveal" data-reveal-delay="<%= i * 75 %>">
            <div class="w-11 h-11 rounded-full bg-brand-red/12 text-brand-red flex items-center justify-center">
              <%= render "pages/icon", name: value[:icon], css_class: "w-5 h-5" %>
            </div>
            <h3 class="mt-5 font-heading text-lg font-semibold"><%= value[:title] %></h3>
            <p class="mt-2 text-sm leading-relaxed"><%= value[:text] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Process steps %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-white px-6 py-20 lg:py-[120px] dm-light-2">
    <div class="max-w-[1200px] mx-auto">
      <div class="reveal max-w-2xl mx-auto text-center" data-controller="reveal">
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-ink-900">So läuft Ihr Termin ab</h2>
        <p class="mt-4 text-mist-600 text-lg">Drei klare Schritte &ndash; ohne Unsicherheiten.</p>
      </div>

      <div class="mt-16 grid gap-12 lg:grid-cols-3 lg:gap-8 relative">
        <div class="hidden lg:block absolute top-6 left-0 right-0 h-px bg-mist-100" aria-hidden="true"></div>
        <% steps.each_with_index do |step, i| %>
          <div class="reveal relative text-center lg:text-left" data-controller="reveal" data-reveal-delay="<%= i * 100 %>">
            <div class="relative z-10 w-12 h-12 mx-auto lg:mx-0 rounded-full bg-brand-red text-mist-50 flex items-center justify-center font-heading text-lg font-semibold">
              <%= i + 1 %>
            </div>
            <h3 class="mt-6 font-heading text-xl font-semibold text-ink-900"><%= raw step[:title] %></h3>
            <p class="mt-3 text-mist-600"><%= step[:text] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Red CTA banner %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-brand-red px-6 py-20">
    <div class="max-w-[1200px] mx-auto text-center text-white">
      <h2 class="font-heading text-3xl md:text-4xl font-semibold">Bereit für Ihren nächsten Termin?</h2>
      <p class="mt-4 text-white/85 text-lg max-w-xl mx-auto">
        Kontaktieren Sie uns &ndash; unverbindlich, transparent und ohne versteckte Kosten.
      </p>
      <a href="/kontakt" class="btn-white mt-8 inline-flex items-center justify-center rounded-full px-8 py-4 text-base">
        Jetzt Kontakt aufnehmen
      </a>
    </div>
  </section>
</main>
