<%
  cs_field = "w-full rounded-lg border border-mist-100 bg-white px-4 py-3 text-ink-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-red transition-shadow"
  cs_label = "block font-heading text-sm font-medium text-ink-900 mb-1.5"
  cs_opts  = [
    "Frage zu Fahrzeug / Sonstiges",
    "Gratis Fahrzeug Check",
    "Service",
    "Reparatur",
    "MFK",
    "Elektronik",
    "Radwechsel / Reifen",
    "KlimaService",
    "Kauf & Verkauf",
    "Andere Services",
    "Anderes",
  ]
%>

<section class="bg-mist-50 px-6 py-16 lg:py-20 dm-light-1">
  <div class="max-w-[1200px] mx-auto grid gap-12 lg:grid-cols-2 items-start">

    <%# Left: heading + contact details %>
    <div class="reveal" data-controller="reveal">
      <p class="font-heading text-sm font-semibold uppercase tracking-wider text-brand-red mb-3">Kontakt</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-ink-900">Termin vereinbaren oder Frage stellen</h2>
      <p class="mt-4 text-mist-600 text-lg leading-relaxed">
        Haben Sie eine Frage zu Ihrem Fahrzeug oder möchten Sie einen Termin buchen? Rufen Sie uns direkt an oder nutzen Sie das Formular &ndash; wir melden uns so schnell wie möglich.
      </p>

      <ul class="mt-8 space-y-4">
        <li class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-red/10 text-brand-red flex items-center justify-center shrink-0 mt-0.5">
            <%= render "pages/icon", name: "phone", css_class: "w-5 h-5" %>
          </div>
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-wide text-mist-600 mb-0.5">Telefon</p>
            <a href="tel:+41318694333" class="text-ink-900 font-medium hover:text-brand-red transition-colors">+41 31 869 43 33</a>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-red/10 text-brand-red flex items-center justify-center shrink-0 mt-0.5">
            <%= render "pages/icon", name: "email", css_class: "w-5 h-5" %>
          </div>
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-wide text-mist-600 mb-0.5">E-Mail</p>
            <a href="mailto:info@garage-hofwil.ch" class="text-ink-900 font-medium hover:text-brand-red transition-colors">info@garage-hofwil.ch</a>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-red/10 text-brand-red flex items-center justify-center shrink-0 mt-0.5">
            <%= render "pages/icon", name: "clock", css_class: "w-5 h-5" %>
          </div>
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-wide text-mist-600 mb-0.5">Öffnungszeiten</p>
            <p class="text-ink-900 font-medium">Mo&ndash;Fr: 08:00&ndash;12:00 / 13:30&ndash;18:30</p>
            <p class="text-mist-600 text-sm">Sa: 09:00&ndash;14:00 &nbsp;&bull;&nbsp; So: Geschlossen</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-red/10 text-brand-red flex items-center justify-center shrink-0 mt-0.5">
            <%= render "pages/icon", name: "location", css_class: "w-5 h-5" %>
          </div>
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-wide text-mist-600 mb-0.5">Adresse</p>
            <p class="text-ink-900 font-medium">Bernstrasse 50, 3053 Münchenbuchsee</p>
          </div>
        </li>
      </ul>
    </div>

    <%# Right: contact form in card %>
    <div class="reveal" data-controller="reveal" data-reveal-delay="100">
      <div class="contact-form-card">
        <%= form_with url: contact_submit_path, method: :post, local: true, class: "grid gap-4" do |form| %>

          <%# Name + Telefon %>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="cs_name" class="<%= cs_label %>">
                Name / Vorname <span class="text-brand-red" aria-hidden="true">*</span>
              </label>
              <%= form.text_field :name,
                id: "cs_name", required: true,
                placeholder: "z. B. Anna Müller",
                class: cs_field %>
            </div>
            <div>
              <label for="cs_telefon" class="<%= cs_label %>">
                Telefonnummer <span class="text-brand-red" aria-hidden="true">*</span>
              </label>
              <%= form.telephone_field :telefon,
                id: "cs_telefon", required: true,
                placeholder: "+41 79 000 00 00",
                class: cs_field %>
            </div>
          </div>

          <%# Email %>
          <div>
            <label for="cs_email" class="<%= cs_label %>">
              E-Mail-Adresse <span class="text-brand-red" aria-hidden="true">*</span>
            </label>
            <%= form.email_field :email,
              id: "cs_email", required: true,
              placeholder: "ihre@email.ch",
              class: cs_field %>
          </div>

          <%# Service dropdown %>
          <div>
            <label for="cs_leistung" class="<%= cs_label %>">Grund der Anfrage</label>
            <%= form.select :leistung, cs_opts,
              { include_blank: "Bitte auswählen …" },
              { id: "cs_leistung", class: cs_field } %>
          </div>

          <%# Message %>
          <div>
            <label for="cs_bemerkung" class="<%= cs_label %>">Bemerkung / Frage</label>
            <%= form.text_area :bemerkung,
              id: "cs_bemerkung", rows: 4,
              placeholder: "Beschreiben Sie kurz Ihr Anliegen …",
              class: "#{cs_field} resize-y" %>
          </div>

          <%= form.submit "Anfrage absenden",
            class: "btn-primary cursor-pointer w-full rounded-full py-4 font-heading text-base font-semibold border-0 mt-1" %>

        <% end %>
      </div>
    </div>

  </div>
</section>
