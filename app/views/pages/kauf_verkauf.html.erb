<%
  trust_points = [
    { icon: "shield-check", title: "Geprüfte Fahrzeuge",   text: "Jedes Fahrzeug wird vor dem Verkauf von unseren Mechanikern geprüft. Sie kaufen mit gutem Gewissen." },
    { icon: "eye",          title: "Transparente Beratung", text: "Wir erklären Ihnen den Zustand des Fahrzeugs ehrlich &ndash; ohne Beschönigungen, ohne versteckte Mängel." },
    { icon: "car",          title: "Probefahrt möglich",   text: "Gerne arrangieren wir eine Probefahrt. Kommen Sie vorbei oder melden Sie sich telefonisch." },
  ]
%>

<main>
  <%# ---------------------------------------------------------------- %>
  <%# Page hero %>
  <%# ---------------------------------------------------------------- %>
  <section class="relative min-h-[52vh] flex items-center justify-center text-center px-6 bg-ink-900 bg-cover bg-center"
           style="background-image: url('<%= asset_path("hero/kauf-verkauf-hero.jpg") %>');">

    <div class="absolute inset-0"
         style="background: linear-gradient(180deg, rgba(10,11,13,0.82) 0%, rgba(10,11,13,0.55) 45%, rgba(10,11,13,0.82) 100%);"></div>

    <div class="relative z-10 max-w-2xl mx-auto pt-20 pb-10">
      <p class="font-heading text-sm font-semibold uppercase tracking-wider text-brand-red mb-3">Fahrzeuge</p>
      <h1 class="font-heading text-4xl md:text-5xl font-semibold text-white leading-tight">Kauf &amp; Verkauf</h1>
      <p class="mt-4 text-white/75 text-lg max-w-2xl mx-auto leading-relaxed">
        Suchen Sie ein geprüftes Occasionsfahrzeug oder möchten Sie Ihr Auto verkaufen? Wir begleiten Sie vertrauensvoll durch den gesamten Prozess.
      </p>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# AutoScout24 Fahrzeugangebote %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-mist-50 px-6 py-20 lg:py-[120px] dm-light-1">
    <div class="max-w-[1200px] mx-auto">
      <div class="reveal max-w-2xl" data-controller="reveal">
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-ink-900">Unsere aktuellen Fahrzeugangebote</h2>
        <p class="mt-4 text-mist-600 text-lg">
          Durchsuchen Sie unsere aktuellen Occasionsfahrzeuge direkt hier &ndash; mit Fotos, Kilometerstand, Preis und allen Fahrzeugdetails von AutoScout24.
        </p>
      </div>

      <div class="mt-10 reveal" data-controller="reveal" data-reveal-delay="100">
        <div class="hci-widget-wrapper">
          <div class="hci-container" data-config-id="23177" data-language="de" data-entry-point="search"></div>
        </div>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Fahrzeug verkaufen %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-white px-6 py-20 lg:py-[120px] dm-light-2">
    <div class="max-w-[1200px] mx-auto grid gap-16 lg:grid-cols-2 items-center">
      <div class="reveal" data-controller="reveal">
        <p class="font-heading text-sm font-semibold uppercase tracking-wider text-brand-red mb-3">Ihr Fahrzeug verkaufen</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-ink-900">Sie möchten Ihr Auto verkaufen?</h2>
        <p class="mt-5 text-mist-600 text-lg leading-relaxed">
          Wir schätzen Ihr Fahrzeug fair ein und helfen Ihnen beim Verkaufsprozess &ndash; unkompliziert und transparent. Kontaktieren Sie uns für eine kostenlose Ersteinschätzung.
        </p>
        <ul class="mt-6 space-y-3 text-mist-600">
          <li class="flex items-start gap-3">
            <%= render "pages/icon", name: "check-circle", css_class: "w-5 h-5 text-brand-red shrink-0 mt-0.5" %>
            <span>Kostenlose Fahrzeugbewertung durch Fachpersonal</span>
          </li>
          <li class="flex items-start gap-3">
            <%= render "pages/icon", name: "check-circle", css_class: "w-5 h-5 text-brand-red shrink-0 mt-0.5" %>
            <span>Fairer Preis, keine Zwischenhändler</span>
          </li>
          <li class="flex items-start gap-3">
            <%= render "pages/icon", name: "check-circle", css_class: "w-5 h-5 text-brand-red shrink-0 mt-0.5" %>
            <span>Schnelle Abwicklung ohne bürokratischen Aufwand</span>
          </li>
        </ul>
        <a href="/kontakt" class="btn-primary mt-8 inline-flex items-center rounded-full px-8 py-4 font-heading text-base font-semibold">
          Fahrzeug bewerten lassen
        </a>
      </div>

      <div class="reveal" data-controller="reveal" data-reveal-delay="150">
        <div class="overflow-hidden rounded-2xl aspect-[4/3] shadow-lg">
          <%= image_tag "workshop/fahrzeug-rot.jpg", alt: "Fahrzeug zum Verkauf", class: "w-full h-full object-cover" %>
        </div>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# Trust points %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-ink-900 px-6 py-20">
    <div class="max-w-[1200px] mx-auto">
      <div class="reveal text-center mb-12" data-controller="reveal">
        <h2 class="font-heading text-3xl font-semibold text-white">Warum bei Garage Hofwil kaufen?</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        <% trust_points.each_with_index do |pt, i| %>
          <div class="trust-card reveal bg-ink-800 border border-white/8 rounded-2xl p-8" data-controller="reveal" data-reveal-delay="<%= i * 80 %>">
            <div class="w-11 h-11 rounded-full bg-brand-red/15 text-brand-red flex items-center justify-center mb-5">
              <%= render "pages/icon", name: pt[:icon], css_class: "w-5 h-5" %>
            </div>
            <h3 class="font-heading text-lg font-semibold text-white"><%= pt[:title] %></h3>
            <p class="mt-2 text-mist-100/65 text-sm leading-relaxed"><%= raw pt[:text] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ---------------------------------------------------------------- %>
  <%# CTA %>
  <%# ---------------------------------------------------------------- %>
  <section class="bg-brand-red px-6 py-16">
    <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-heading text-2xl md:text-3xl font-semibold text-white">Fragen zu einem Fahrzeug?</h2>
        <p class="text-white/80 mt-1">Rufen Sie uns an oder schreiben Sie uns &ndash; wir beraten Sie gerne.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a href="tel:+41318694333" class="btn-white inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-sm font-heading font-semibold">
          <%= render "pages/icon", name: "phone", css_class: "w-4 h-4" %>
          +41 31 869 43 33
        </a>
        <a href="/kontakt" class="inline-flex items-center justify-center rounded-full px-7 py-3.5 font-heading text-sm font-semibold text-white border border-white/40 hover:border-white hover:bg-white/10 transition-colors">
          Kontaktformular
        </a>
      </div>
    </div>
  </section>
</main>

<% content_for :page_scripts do %>
  <script src="https://www.autoscout24.ch/assets/hci/v2/hci.current.js"></script>
  <script>
    document.addEventListener("turbo:load", function () {
      if (window.hci && document.querySelector(".hci-container")) {
        window.hci.run();
      }
    });
  </script>
<% end %>
